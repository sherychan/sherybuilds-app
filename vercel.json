{
  "trailingSlash": true,
  "headers": [
    {
      "source": "/pq34/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/pq34/",
      "headers": [
        { "key": "Cache-Control", "value": "private, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
